# SUGAM Environment Configuration
# ===============================

# --- Global Settings ---
ENVIRONMENT=production
PROJECT_NAME=sugam

# --- Frontend Settings ---
# Use the public hostname or IP of your server
NEXT_PUBLIC_API_URL=http://localhost/api/v1

# --- Backend Settings ---
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Database Credentials (STRICTLY FOR INTERNAL CONTAINER NETWORK) ---
POSTGRES_USER=sugam_admin
POSTGRES_PASSWORD=sugam_pass
POSTGRES_DB=sugam_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

MONGO_USER=
MONGO_PASS=
MONGO_DB=sugam_nosql
MONGO_HOST=mongo
MONGO_PORT=27017

# --- Database URLs (Used by services) ---
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
MONGO_URL=mongodb://${MONGO_HOST}:${MONGO_PORT}/
